# -----------------------------------------------------------------------------
# ONFANS Environment Variables Template
# 
# [사용 방법]
# 1. 이 파일의 이름을 `.env.local` 로 변경하세요.
# 2. 아래 값들을 실제 사용하시는 서비스의 키 값으로 채워넣으세요.
# -----------------------------------------------------------------------------

# [1] Supabase 설정 (필수)
# Supabase 대시보드 -> Project Settings -> API 에서 확인 가능합니다.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# [2] 포트원(Portone) 설정 (옵션 - 결제 모듈용)
# 포트원 관리자 콘솔 -> 가맹점 식별코드
# (기본값은 테스트용 식별코드인 imp00000000 로 설정되어 있습니다)
VITE_PORTONE_IMP_CODE=imp00000000

# ※ 참고: Make.com 웹훅 URL의 경우 프론트엔드가 아닌
# 백엔드(Supabase Database Webhooks)에서 처리되므로 이곳에 적을 필요가 없습니다.
# `supabase_webhooks.sql` 파일을 열어 SQL 스크립트 안에 기입하셔야 합니다!
